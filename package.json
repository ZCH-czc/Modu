{
  "name": "modu-reader-v3",
  "version": "1.5.5",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --dev-client --android",
    "ios": "expo run:ios",
    "typecheck": "tsc --noEmit",
    "android:build": "expo run:android",
    "android:release": "powershell -ExecutionPolicy Bypass -File ./scripts/build-android.ps1",
    "test:book-source": "node --use-env-proxy scripts/test-book-source.mjs"
  },
  "dependencies": {
    "@expo/vector-icons": "15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~57.0.6",
    "expo-brightness": "~57.0.1",
    "expo-dev-client": "~57.0.6",
    "expo-document-picker": "~57.0.1",
    "expo-file-system": "~57.0.1",
    "expo-keep-awake": "~57.0.1",
    "expo-linear-gradient": "~57.0.1",
    "expo-notifications": "~57.0.5",
    "expo-screen-orientation": "~57.0.1",
    "expo-splash-screen": "~57.0.4",
    "expo-status-bar": "~57.0.1",
    "expo-system-ui": "~57.0.1",
    "fast-xml-parser": "5.10.0",
    "jszip": "3.10.1",
    "node-html-parser": "^9.0.0",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-webview": "13.16.1",
    "react-native-worklets": "0.10.0",
    "@expo/metro-runtime": "~57.0.5",
    "react-dom": "19.2.3",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@types/react": "~19.2.17",
    "typescript": "~6.0.3"
  },
  "packageManager": "pnpm@11.9.0",
  "description": "A polished local-first reader for EPUB, PDF, dynamic book sources, and the web."
}
