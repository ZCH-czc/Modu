{
  "expo": {
    "name": "\u58A8\u8BFB",
    "slug": "modu-reader-v3",
    "version": "1.5.8",
    "orientation": "default",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "plugins": [
      "expo-document-picker",
      "expo-screen-orientation",
      "expo-dev-client",
      "expo-notifications",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F7F4ED",
          "image": "./assets/splash.png",
          "imageWidth": 220,
          "resizeMode": "contain"
        }
      ]
    ],
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F7F4ED"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "versionCode": 12,
      "predictiveBackGestureEnabled": true,
      "icon": "./assets/icon.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F7F4ED"
      },
      "package": "com.modureader.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "description": "A calm, local-first reader for books from files, dynamic sources, and the web."
  }
}